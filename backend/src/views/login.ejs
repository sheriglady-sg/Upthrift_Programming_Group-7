<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | UpThrift</title>
    <link rel="stylesheet" href="/css/mainlogin.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <style>
        .login-body {
            background-color: #f2f2ee;
            font-family: var(--font-body); 
        }
        .form-content {
            padding: 60px 12%;
        }
        .login-badge {
            background: #e9e9e9;
            padding: 6px 14px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1px;
            color: var(--color-text-secondary);
            border-radius: 4px;
            font-family: var(--font-body);
        }
        .page-title {
            font-family: var(--font-display); 
            font-size: 36px;
            margin-top: 20px;
            color: var(--color-text-primary);
        }
        .forget-password {
            display: inline-block;
            margin-top: 10px;
            font-size: 13px;
            color: #4a6fa5;
            text-decoration: none;
            font-family: var(--font-body);
        }
        .signup-link-text {
            margin-top: 25px;
            font-size: 14px;
            color: var(--color-text-secondary);
            font-family: var(--font-body);
        }
        .signup-link-text a {
            color: #4a6fa5;
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>
<body class="login-body">

    <%- include('components/topbar-guest') %>

    <main class="split-container" style="min-height: 85vh;">
        <section class="form-side">
            <div class="form-content">
                <span class="login-badge">LOGIN</span>
                
                <h1 class="page-title">Welcome Back</h1>
                <p class="post-content" style="margin-bottom: 30px; font-family: var(--font-body);">Sign in to your account</p>

                <form action="/auth/login" method="POST" class="styled-form" style="max-width: 400px;">
                    <div class="form-group">
                        <label class="form-label" style="font-family: var(--font-body); font-weight: 500;">Email</label>
                        <input type="email" name="email" class="comment-input" placeholder="your@email.com" required>
                    </div>

                    <div class="form-group" style="margin-top: 20px;">
                        <label class="form-label" style="font-family: var(--font-body); font-weight: 500;">Password</label>
                        <input type="password" name="password" class="comment-input" placeholder="........" required>
                    </div>

                    <a href="/forget-password" class="forget-password">Forgot Password?</a>

                    <button type="submit" class="btn-post" style="width: 100%; margin-top: 30px; padding: 14px; border: none; cursor: pointer;">
                        Sign In
                    </button>

                    <p class="signup-link-text">
                        Don't have an account? <a href="/signup">Sign up</a>
                    </p>
                </form>
            </div>
        </section>

        <section class="image-side">
            <img src="/images/Login.png" alt="Ethnic Fabric Decor" style="width: 100%; height: 100%; object-fit: cover;">
        </section>
    </main>

    <%- include('components/footer') %>

</body>
</html>