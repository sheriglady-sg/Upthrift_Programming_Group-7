<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpThrift – Post Details</title>
  <link rel="stylesheet" href="/css/mainlogin.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
</head>
<body>
<!-- Topbar -->
  <%- include('components/topbar') %>
<!-- sidebar -->
  <div class="navigation">
    <%- include('components/sidebar', { activePage }) %>

    <main class="main-content main-content--details">
      <div class="page-header-row page-header-row--details">
        <a href="/feed" class="back-link">
          <span class="back-arrow">←</span> Back to Feed
        </a>
        <span class="breadcrumb-tag">POST DETAILS</span>
      </div>

      <% if (message) { %>
        <div class="form-message success-message"><%= message %></div>
      <% } %>

      <% if (error) { %>
        <div class="form-message error-message"><%= error %></div>
      <% } %>

      <div class="post-card post-card--detail">
          <div class="post-header">
              <a href="/user/<%= post.authorSlug %>" class="post-author-link">
                <% if (post.authorAvatar) { %>
                  <img src="<%= post.authorAvatar %>" alt="<%= post.author %>" class="post-avatar-img">
                <% } else { %>
                  <div class="avatar-placeholder small"></div>
                <% } %>
              </a>
            <div class="post-meta">
              <a href="/user/<%= post.authorSlug %>" class="post-author post-author-link">
                <%= post.author %>
              </a>
            <span class="post-time"><%= post.fullDate || post.timeAgo %></span>
          </div>
        </div>
        <p class="post-content"><%= post.content %></p>
        <% if (post.image && post.mediaType === "video") { %>
          <video src="<%= post.image %>" class="post-media-img post-media-img--large" controls></video>
        <% } else if (post.image) { %>
          <img src="<%= post.image %>" alt="<%= post.content %>" class="post-media-img post-media-img--large">
        <% } else { %>
          <div class="post-media-placeholder post-media-placeholder--large">Post Image/Video</div>
        <% } %>
        <div class="post-actions">
          <div class="post-actions-left">
            <button class="action-btn like-btn" aria-label="Like">
              <img src="/images/Heart_02.svg" alt="Like" style="height: 20px;">
              <span class="action-count"><%= post.likes %></span>
            </button>
            <button class="action-btn" aria-label="Comments">
              <img src="/images/Chat_Circle_Dots.svg" alt="Comments" style="height: 18px;">
              <span class="action-count"><%= post.comments %></span>
            </button>
          </div>
          <div class="post-actions-right">
            <form action="/posts/<%= post.id %>/save" method="POST" style="display:inline;">
              <button class="action-btn" aria-label="Bookmark" type="submit" style="<%= post.isSaved ? 'background:#eef4e6;border-radius:999px;' : '' %>">
                <img src="/images/Bookmark.svg" alt="Bookmark" style="height: 20px;">
              </button>
            </form>
            <button class="action-btn" aria-label="Share">
              <img src="/images/Navigation.svg" alt="Share" style="height: 18px;">
            </button>
          </div>
        </div>
      </div>

      <section class="comments-section">
        <h2 class="comments-title">Comments</h2>

        <div class="comments-list">
          <% if (post.commentList.length === 0) { %>
            <div class="comments-area-placeholder">No comments yet</div>
          <% } %>

          <% post.commentList.forEach(comment => { %>
            <div class="comment-item">
              <a href="/user/<%= comment.authorSlug %>">
                <% if (comment.authorAvatar) { %>
                  <img src="<%= comment.authorAvatar %>" alt="<%= comment.author %>" class="comment-avatar-img">
                <% } else { %>
                  <div class="avatar-placeholder xsmall"></div>
                <% } %>
              </a>
              <div class="comment-body">
                <a href="/user/<%= comment.authorSlug %>" class="comment-author-link">
                  <%= comment.author %>
                </a>
                <p class="comment-text"><%= comment.text %></p>
                <span class="comment-time"><%= comment.timeAgo %></span>
              </div>
            </div>
          <% }) %>
        </div>

        <% if (currentUser) { %>
          <form action="/posts/<%= post.id %>/comment" method="POST" class="comment-input-row">
            <input type="text" name="content" class="comment-input" placeholder="Add a comment..." />
            <button type="submit" class="comment-send-btn" aria-label="Send comment">
              <span class="send-icon">➤</span>
            </button>
          </form>
        <% } else { %>
          <div class="comments-area-placeholder">Log in to leave a comment</div>
        <% } %>
      </section>
    </main>
  </div>
<!-- footer -->
  <%- include('components/footerlogin') %>

</body>
</html>
