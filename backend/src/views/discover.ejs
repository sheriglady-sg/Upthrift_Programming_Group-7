<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpThrift – Discover</title>
  <link rel="stylesheet" href="/css/mainlogin.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
</head>
<body>
  <%- include('components/topbar') %>
  <div class="navigation">
    <%- include('components/sidebar', { activePage }) %>
    <main class="main-content main-content--discover">

      <span class="breadcrumb-tag" style="display:inline-block;margin-bottom:20px;">DISCOVER</span>

      <!-- Search + Filter -->
      <form action="/discover" method="GET" class="discover-search-row">
        <div class="discover-search-wrap">
          <span class="discover-search-icon">🔍</span>
          <input
            type="text"
            name="q"
            class="discover-search-input"
            placeholder="Search thrift stores..."
            value="<%= query %>"
          />
        </div>
        <button type="submit" class="btn-filter">Filter</button>
      </form>

      <!-- Store list -->
      <div class="store-list">
        <% stores.forEach(store => { %>
        <div class="store-card">
          <div class="store-card-img">
            <!-- REPLACE: <img src="/images/<%= store.slug %>.jpg" class="store-thumb"> -->
          </div>
          <div class="store-card-body">
            <h2 class="store-name"><%= store.name %></h2>
            <div class="store-meta-row">
              <span class="store-star">★</span>
              <span class="store-rating"><%= store.rating %></span>
              <span class="store-reviews">(<%= store.reviewCount %> reviews)</span>
              <span class="store-distance-icon">📍</span>
              <span class="store-distance"><%= store.distance %></span>
            </div>
            <p class="store-desc"><%= store.description %></p>
          </div>
          <div class="store-card-actions">
            <a href="/store/<%= store.slug %>" class="btn-view-details">View Details</a>
          </div>
        </div>
        <% }) %>
        <% if (stores.length === 0) { %>
        <div class="discover-empty">No stores found for "<%= query %>".</div>
        <% } %>
      </div>

    </main>
  </div>
  <%- include('components/footerlogin') %>
</body>
</html>
