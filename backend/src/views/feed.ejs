<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpThrift – Home/Feed</title>
  <link rel="stylesheet" href="/css/mainlogin.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
</head>
<body>

  <%- include('components/topbar') %>

  <div class="navigation">
    <%- include('components/sidebar', { activePage }) %>

    <main class="main-content">
      <div class="page-header-row">
        <nav class="breadcrumb">HOME/FEED</nav>
        <a href="/create-post" class="btn-create-post">
          <span class="plus-icon">+</span> Create Post
        </a>
      </div>

      <h1 class="page-title">Your Feed</h1>

      <% if (message) { %>
      <div class="form-message success-message"><%= message %></div>
      <% } %>

      <% if (error) { %>
      <div class="form-message error-message"><%= error %></div>
      <% } %>

      <div class="feed-scroll-hint">View Feed / Scroll</div>

      <div class="posts-list">
        <% posts.forEach(post => { %>
        <article class="post-card">
          <div class="post-header">
            <div class="avatar-placeholder small"></div>
            <div class="post-meta">
              <span class="post-author"><%= post.author %></span>
              <span class="post-time"><%= post.timeAgo %></span>
            </div>
          </div>
          <p class="post-content"><%= post.content %></p>
          <a href="/post/<%= post.id %>">
            <div class="post-media-placeholder">Post Image/Video</div>
          </a>
          <div class="post-actions">
            <div class="post-actions-left">
              <button class="action-btn like-btn" aria-label="Like">
                <span class="action-icon">🤍</span>
                <span class="action-count"><%= post.likes %></span>
              </button>
              <a href="/post/<%= post.id %>" class="action-btn comment-btn" aria-label="Comments">
                <span class="action-icon">💬</span>
                <span class="action-count"><%= post.comments %></span>
              </a>
            </div>
            <div class="post-actions-right">
              <button class="action-btn" aria-label="Bookmark">
                <span class="action-icon">🔖</span>
              </button>
              <button class="action-btn" aria-label="Share">
                <span class="action-icon">↗</span>
              </button>
            </div>
          </div>
        </article>
        <% }) %>
      </div>
    </main>
  </div>

  <%- include('components/footerlogin') %>

</body>
</html>
