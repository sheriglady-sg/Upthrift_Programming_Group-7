<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpThrift – Home/Feed</title>
  <link rel="stylesheet" href="/css/mainlogin.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
</head>
<body>
<!-- Topbar -->
  <%- include('components/topbar') %>
<!-- Sidebar -->
  <div class="navigation">
    <%- include('components/sidebar', { activePage }) %>

    <main class="main-content">
      <div class="page-header-row">
        <nav class="breadcrumb">HOME/FEED</nav>
        <a href="/create-post" class="btn-create-post">
          <span class="plus-icon">+</span> Create Post
        </a>
      </div>

      <h1 class="page-title">Your Feed</h1>
      <div class="feed-scroll-hint">View Feed / Scroll</div>
<!-- Posts feeds -->
      <div class="posts-list">
        <% posts.forEach(post => { %>
        <article class="post-card">
          <div class="post-header">
            <a href="/user/<%= post.authorSlug %>" class="post-author-link">
              <% if (post.authorAvatar) { %>
                <img src="<%= post.authorAvatar %>" alt="<%= post.author %>" class="post-avatar-img">
              <% } else { %>
                <div class="avatar-placeholder small"></div>
              <% } %>
            </a>
            <div class="post-meta">
              <a href="/user/<%= post.authorSlug %>" class="post-author post-author-link">
                <%= post.author %>
              </a>
              <span class="post-time"><%= post.timeAgo %></span>
            </div>
          </div>
          <p class="post-content"><%= post.content %></p>
          <% if (post.image && post.mediaType === "video") { %>
            <a href="/post/<%= post.id %>">
              <video src="<%= post.image %>" class="post-media-img" controls></video>
            </a>
          <% } else if (post.image) { %>
            <a href="/post/<%= post.id %>">
              <img src="<%= post.image %>" alt="<%= post.content %>" class="post-media-img">
            </a>
          <% } %>
          <div class="post-actions">
            <div class="post-actions-left">
              <form action="/posts/<%= post.id %>/like" method="POST" style="display:inline;">
                <button class="action-btn like-btn" aria-label="Like" type="submit">
                  <img src="/images/Heart_02.svg" alt="Like" style="height: 20px;">
                  <span class="action-count"><%= post.likes %></span>
                </button>
              </form>
              <a href="/post/<%= post.id %>" class="action-btn comment-btn" aria-label="Comments">
                <img src="/images/Chat_Circle_Dots.svg" alt="Comments" style="height: 18px;">
                <span class="action-count"><%= post.comments %></span>
              </a>
            </div>
            <div class="post-actions-right">
              <form action="/posts/<%= post.id %>/save" method="POST" style="display:inline;">
                <button class="action-btn" aria-label="Bookmark" type="submit" style="<%= post.isSaved ? 'background:#7f8f63;border-radius:999px;border-color:#7f8f63;' : '' %>">
                  <img src="/images/Bookmark.svg" alt="Bookmark" style="height: 18px;<%= post.isSaved ? 'filter:brightness(0) invert(1);' : '' %>">
                </button>
              </form>
              <button class="action-btn" aria-label="Share" type="button" onclick="sharePost('/post/<%= post.id %>')">
                <img src="/images/Navigation.svg" alt="Share" style="height: 18px;">
              </button>
            </div>
          </div>
        </article>
        <% }) %>
      </div>
    </main>
  </div>
<!-- Footer -->
  <%- include('components/footerlogin') %>

  <script>
    async function sharePost(path) {
      const fullUrl = window.location.origin + path;

      if (navigator.share) {
        try {
          await navigator.share({
            title: "UpThrift Post",
            url: fullUrl
          });
          return;
        } catch (error) {
        }
      }

      if (navigator.clipboard && window.isSecureContext) {
        try {
          await navigator.clipboard.writeText(fullUrl);
          alert("Post link copied");
          return;
        } catch (error) {
        }
      }

      const input = document.createElement("input");
      input.value = fullUrl;
      document.body.appendChild(input);
      input.select();
      document.execCommand("copy");
      document.body.removeChild(input);
      alert("Post link copied");
    }
  </script>

</body>
</html>
