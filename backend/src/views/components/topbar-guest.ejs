<%
  const currentPage = typeof activePage === "string" ? activePage : "";
  const loginIsActive = currentPage === "login" || currentPage === "signup" || currentPage === "forget-password";
  const aboutStyle = currentPage === "about"
    ? "margin-right: 18px; font-size: 13.5px; text-decoration: none; color: var(--color-text-primary); font-weight: 600;"
    : "margin-right: 18px; font-size: 13.5px; text-decoration: none;";
  const contactStyle = currentPage === "contact"
    ? "margin-right: 18px; font-size: 13.5px; text-decoration: none; color: var(--color-text-primary); font-weight: 600;"
    : "margin-right: 18px; font-size: 13.5px; text-decoration: none;";
  const loginStyle = loginIsActive
    ? "text-decoration: none; padding: 6px 20px;"
    : "text-decoration: none; padding: 6px 20px; background: transparent; color: var(--color-text-primary); border: 1px solid var(--color-border);";
%>
<header class="topbar">
  <div class="logo-link">
    <a href="/" class="logo-text" style="text-decoration: none;">UpThrift</a>
  </div>

  <div class="topbar-actions">
    <a href="/about" class="footer-link" style="<%= aboutStyle %>">About</a>
    <a href="/contact" class="footer-link" style="<%= contactStyle %>">Contact</a>

    <a href="/login" class="btn-create-post" style="<%= loginStyle %>">Login</a>
  </div>
</header>
