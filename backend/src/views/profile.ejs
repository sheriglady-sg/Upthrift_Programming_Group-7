<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpThrift – Profile</title>
  <link rel="stylesheet" href="/css/mainlogin.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
</head>
<body>

  <%- include('components/topbar') %>

  <div class="navigation">
    <%- include('components/sidebar', { activePage }) %>

    <main class="main-content main-content--profile">

      <!-- Breadcrumb -->
      <div class="breadcrumb-tag-row">
        <span class="breadcrumb-tag profile-breadcrumb">PROFILE</span>
      </div>

      <!-- Profile card -->
      <div class="profile-card">
        <div class="profile-card-inner">
          <!-- Avatar -->
          <div class="profile-avatar-wrap">
            <!-- REPLACE: <img src="/images/avatar.jpg" class="profile-avatar-img"> -->
            <div class="profile-avatar-placeholder"><%= profile.initials %></div>
          </div>

          <!-- Info -->
          <div class="profile-info">
            <div class="profile-info-top">
              <div>
                <h1 class="profile-name"><%= profile.name %></h1>
                <p class="profile-username"><%= profile.username %></p>
                <p class="profile-bio"><%= profile.bio %></p>
                <div class="profile-stats">
                  <span class="profile-stat"><strong><%= profile.posts %></strong> Posts</span>
                  <span class="profile-stat"><strong><%= profile.followers %></strong> Followers</span>
                  <span class="profile-stat"><strong><%= profile.following %></strong> Following</span>
                </div>
              </div>
              <div class="profile-actions">
                <button class="btn-profile-action">
                  <!-- REPLACE: share icon -->
                  <span class="profile-action-icon">↗</span> Share Profile
                </button>
                <button class="btn-profile-action">
                  <!-- REPLACE: edit icon -->
                  <span class="profile-action-icon">✏️</span> Edit Profile
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="profile-tabs">
        <a href="/profile" class="profile-tab <%= activeTab === 'posts' ? 'profile-tab--active' : '' %>">
          <!-- REPLACE: grid icon -->
          <span class="tab-icon">⊞</span> Posts
        </a>
        <a href="/profile/saved" class="profile-tab <%= activeTab === 'saved' ? 'profile-tab--active' : '' %>">
          <!-- REPLACE: bookmark icon -->
          <span class="tab-icon">🔖</span> Saved Posts
        </a>
      </div>

      <!-- Grid -->
      <div class="profile-grid">
        <% if (activeTab === 'posts') { %>
          <% profile.myPosts.forEach(p => { %>
          <a href="/post/<%= p.id %>" class="profile-grid-item">
            <div class="profile-grid-placeholder"><%= p.label %></div>
          </a>
          <% }) %>
        <% } else { %>
          <% profile.savedPosts.forEach(p => { %>
          <a href="/post/<%= p.id %>" class="profile-grid-item">
            <div class="profile-grid-placeholder"><%= p.label %></div>
          </a>
          <% }) %>
        <% } %>
      </div>

    </main>
  </div>

  <%- include('components/footerlogin') %>

</body>
</html>
