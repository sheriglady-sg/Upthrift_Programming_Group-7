<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpThrift – Profile</title>
  <link rel="stylesheet" href="/css/mainlogin.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
</head>
<body>
<!-- Topbar -->
  <%- include('components/topbar') %>
<!-- sidebar -->
  <div class="navigation">
    <%- include('components/sidebar', { activePage }) %>

    <main class="main-content main-content--profile">

      <!-- Breadcrumb -->
      <div class="breadcrumb-tag-row">
        <span class="breadcrumb-tag profile-breadcrumb">PROFILE</span>
      </div>

      <!-- Profile card -->
      <div class="profile-card">
        <div class="profile-card-inner">
          <!-- Avatar -->
          <div class="profile-avatar-wrap">
            <% if (profile.avatar) { %>
              <img src="<%= profile.avatar %>" alt="<%= profile.name %>" class="profile-avatar-img">
            <% } else { %>
              <div class="profile-avatar-placeholder"><%= profile.initials %></div>
            <% } %>
          </div>

          <!-- Info -->
          <div class="profile-info">
            <div class="profile-info-top">
              <div>
                <h1 class="profile-name"><%= profile.name %></h1>
                <p class="profile-username"><%= profile.username %></p>
                <p class="profile-bio"><%= profile.bio %></p>
                <div class="profile-stats">
                  <span class="profile-stat"><strong><%= profile.posts %></strong> Posts</span>
                  <span class="profile-stat"><strong><%= profile.followers %></strong> Followers</span>
                  <span class="profile-stat"><strong><%= profile.following %></strong> Following</span>
                </div>
              </div>
              <div class="profile-actions">
                <button class="btn-profile-action" type="button" onclick="shareProfile()">
                  <img src="/images/Navigation.svg" alt="Share Profile" style="height: 18px;">Share Profile
                </button>
                <button class="btn-profile-action">
                 <a href="/settings" style="color:inherit;">
                  <img src="/images/Edit_Pencil_01.svg" alt="Edit Profile" style="height: 18px; margin-right: 5px;">Edit Profile
                </a>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="profile-tabs">
        <a href="/profile" class="profile-tab <%= activeTab === 'posts' ? 'profile-tab--active' : '' %>">
          <!-- grid icon -->
          <img src="/images/Image_01.svg" alt="Posts" style="height: 18px;"> Posts
        </a>
        <a href="/profile/saved" class="profile-tab <%= activeTab === 'saved' ? 'profile-tab--active' : '' %>">
          <!-- bookmark -->
          <img src="/images/Bookmark.svg" alt="Saved Posts" style="height: 18px;"> Saved Posts
        </a>
      </div>

      <!-- Post Grid -->
      <div class="profile-grid">
        <% if (activeTab === 'posts') { %>
          <% if (profile.myPosts.length === 0) { %>
            <div class="profile-grid-placeholder">No posts yet</div>
          <% } %>
          <% profile.myPosts.forEach(p => { %>
            <a href="/post/<%= p.id %>" class="profile-grid-item">
              <% if (p.image) { %>
                <img src="<%= p.image %>" alt="<%= p.label %>" class="profile-grid-img">
              <% } else { %>
                <div class="profile-grid-placeholder"><%= p.label %></div>
              <% } %>
            </a>
          <% }) %>
        <% } else { %>
          <% if (profile.savedPosts.length === 0) { %>
            <div class="profile-grid-placeholder">No saved posts yet</div>
          <% } %>
          <% profile.savedPosts.forEach(p => { %>
            <a href="/post/<%= p.id %>" class="profile-grid-item">
              <% if (p.image) { %>
                <img src="<%= p.image %>" alt="<%= p.label %>" class="profile-grid-img">
              <% } else { %>
                <div class="profile-grid-placeholder"><%= p.label %></div>
              <% } %>
            </a>
          <% }) %>
        <% } %>
      </div>

    </main>
  </div>
<!-- footer -->
  <%- include('components/footerlogin') %>

  <script>
    async function shareProfile() {
      const fullUrl = window.location.origin + "/profile";

      if (navigator.share) {
        try {
          await navigator.share({
            title: "UpThrift Profile",
            url: fullUrl
          });
          return;
        } catch (error) {
        }
      }

      if (navigator.clipboard && window.isSecureContext) {
        try {
          await navigator.clipboard.writeText(fullUrl);
          alert("Profile link copied");
          return;
        } catch (error) {
        }
      }

      const input = document.createElement("input");
      input.value = fullUrl;
      document.body.appendChild(input);
      input.select();
      document.execCommand("copy");
      document.body.removeChild(input);
      alert("Profile link copied");
    }
  </script>

</body>
</html>
