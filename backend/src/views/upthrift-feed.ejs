<!-- upthrift-feed.ejs: EJS template for the UPTHRIFT Home/Feed design -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1383, initial-scale=1.0">
  <title>UPTHRIFT Feed</title>
  <link rel="stylesheet" href="/styles/upthrift-feed.css">
</head>
<body>
  <div class="feed-bg">
    <!-- Sidebar Navigation -->
    <aside class="sidebar">
      <nav class="sidebar-nav">
        <a class="sidebar-link active"><img src="http://localhost:3845/assets/60aa3f6214d1f990f0ddb463641916b564d81e6b.svg" alt="Home"/> Home/Feed</a>
        <a class="sidebar-link"><img src="http://localhost:3845/assets/2495adfde675942027de88833e25b4867a5f47ba.svg" alt="Discover"/> Discover</a>
        <a class="sidebar-link"><img src="http://localhost:3845/assets/180d750fe86963bdae82df451a8481be9e25f93b.svg" alt="Forum"/> Forum</a>
        <a class="sidebar-link"><img src="http://localhost:3845/assets/8611c672021a05f92d5c6b349c5d4f56dfb6bdc6.svg" alt="Events"/> Events</a>
        <a class="sidebar-link highlight"><img src="http://localhost:3845/assets/b060cafd5867f4eed7ac03458f6c5f5c58756a36.svg" alt="Messages"/> Messages</a>
        <a class="sidebar-link"><img src="http://localhost:3845/assets/cd5021e58fad0fa353881d71fe6bc8009e05c484.svg" alt="Profile"/> Profile</a>
      </nav>
    </aside>
    <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      <header class="main-header">
        <div class="logo-header">
          <img src="http://localhost:3845/assets/7a8ad68f83b0d5ac40c26b23c92051623ca4355c.png" alt="UPTHRIFT Logo" class="logo-img"/>
        </div>
        <div class="header-actions">
          <img src="http://localhost:3845/assets/846483826e878452a5da58224729bace55812482.svg" alt="User" class="header-avatar"/>
          <button class="header-btn"><img src="http://localhost:3845/assets/ffa85b4e0e863c5e5d55fdb7e5009dbd125739d3.svg" alt="Bell"/></button>
          <button class="header-btn"><img src="http://localhost:3845/assets/a5b2c493a4601c2252c73c73169724744ed8e245.svg" alt="Settings"/></button>
        </div>
      </header>
      <!-- Feed Section -->
      <section class="feed-section">
        <div class="feed-header">
          <div class="feed-title-box">
            <span class="feed-title-label">HOME/FEED</span>
            <h1 class="feed-title">Your Feed</h1>
          </div>
          <button class="create-post-btn"><img src="http://localhost:3845/assets/3d92008ead4a282a3e2377b670cb17c75bd462c6.svg" alt="Plus"/> Create Post</button>
        </div>
        <div class="feed-scroll-label">View Feed / Scroll</div>
        <!-- Feed Cards -->
        <div class="feed-cards">
          <div class="feed-card">
            <div class="card-user-row">
              <div class="user-avatar"></div>
              <div class="user-info">
                <span class="user-name">Sarah M.</span>
                <span class="user-time">2 hours ago</span>
              </div>
            </div>
            <div class="card-text">Check out this vintage jacket I found!</div>
            <div class="card-media">Post Image/Video</div>
            <div class="card-actions">
              <span class="card-action"><img src="http://localhost:3845/assets/e2cb3f1a9f066d02a3c2c2b9ab28900486303c6c.svg" alt="Heart"/> 24</span>
              <span class="card-action"><img src="http://localhost:3845/assets/426e0a27cccf190efcaec50a451d97961c17707a.svg" alt="Message"/> 5</span>
              <span class="card-action"><img src="http://localhost:3845/assets/72abbe045fe28d120d340e183d52531af3261660.svg" alt="Bookmark"/></span>
              <span class="card-action"><img src="http://localhost:3845/assets/efed8e404dfa228684b19438b6648eec6d5f493f.png" alt="Share"/></span>
            </div>
          </div>
          <div class="feed-card">
            <div class="card-user-row">
              <div class="user-avatar"></div>
              <div class="user-info">
                <span class="user-name">Mike R.</span>
                <span class="user-time">2 hours ago</span>
              </div>
            </div>
            <div class="card-text">Upcycled these old jeans into a tote bag</div>
            <div class="card-media">Post Image/Video</div>
            <div class="card-actions">
              <span class="card-action"><img src="http://localhost:3845/assets/e2cb3f1a9f066d02a3c2c2b9ab28900486303c6c.svg" alt="Heart"/> 24</span>
              <span class="card-action"><img src="http://localhost:3845/assets/426e0a27cccf190efcaec50a451d97961c17707a.svg" alt="Message"/> 5</span>
              <span class="card-action"><img src="http://localhost:3845/assets/72abbe045fe28d120d340e183d52531af3261660.svg" alt="Bookmark"/></span>
              <span class="card-action"><img src="http://localhost:3845/assets/efed8e404dfa228684b19438b6648eec6d5f493f.png" alt="Share"/></span>
            </div>
          </div>
          <div class="feed-card">
            <div class="card-user-row">
              <div class="user-avatar"></div>
              <div class="user-info">
                <span class="user-name">Emma L.</span>
                <span class="user-time">2 hours ago</span>
              </div>
            </div>
            <div class="card-text">Amazing thrift haul from downtown!</div>
            <div class="card-media">Post Image/Video</div>
            <div class="card-actions">
              <span class="card-action"><img src="http://localhost:3845/assets/e2cb3f1a9f066d02a3c2c2b9ab28900486303c6c.svg" alt="Heart"/> 24</span>
              <span class="card-action"><img src="http://localhost:3845/assets/426e0a27cccf190efcaec50a451d97961c17707a.svg" alt="Message"/> 5</span>
              <span class="card-action"><img src="http://localhost:3845/assets/72abbe045fe28d120d340e183d52531af3261660.svg" alt="Bookmark"/></span>
              <span class="card-action"><img src="http://localhost:3845/assets/efed8e404dfa228684b19438b6648eec6d5f493f.png" alt="Share"/></span>
            </div>
          </div>
        </div>
      </section>
      <!-- Footer -->
      <footer class="main-footer">
        <div class="footer-logo"><img src="http://localhost:3845/assets/7a8ad68f83b0d5ac40c26b23c92051623ca4355c.png" alt="UPTHRIFT Logo"/></div>
        <div class="footer-links">
          <a>Privacy Policy</a>
          <span class="footer-divider"><img src="http://localhost:3845/assets/827064e792f4602c95a9fbe3d4f2cb241ada5e37.svg" alt="|"/></span>
          <a>Terms of Service</a>
        </div>
        <div class="footer-meta">
          <span class="footer-location"><img src="http://localhost:3845/assets/012326763a342a928fbb359273e9c35414faf4c6.svg" alt="MapPin"/> Dublin, IE</span>
          <span class="footer-email"><img src="http://localhost:3845/assets/118b6a54c110d6ef3363c598f79dd6f268d7e659.svg" alt="Mail"/> hello@upthrift.ie</span>
        </div>
        <div class="footer-desc">Connecting thrifters, upcyclers, and sustainable shoppers.</div>
        <div class="footer-copyright">© 2026 UPTHRIFT. All rights reserved.</div>
      </footer>
    </main>
  </div>
</body>
</html>
