<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UpThrift | Landing Page</title>
    <link rel="stylesheet" href="/css/mainlogin.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
</head>
<body class="landing-page" style="font-family: var(--font-body);">

    <%- include('components/topbar-guest') %>

    <main class="main-content">
        
        <section class="post-card post-card--detail" style="text-align: center; padding: 60px 20px;">
            <span class="breadcrumb" style="font-family: var(--font-body);">LANDING PAGE</span>
            <h1 class="page-title" style="font-family: var(--font-display); font-size: 42px; margin-top: 20px;">Share Thrift Finds, Upcycling Ideas</h1>
            <p class="post-content" style="font-family: var(--font-body); font-size: 16px; color: var(--color-text-secondary); margin-bottom: 30px;">
                Discover local thrift stores and events. Join a community of <br>
                sustainable shoppers and creative upcyclers.
            </p>
            <a href="/get-started" class="btn-post" style="font-family: var(--font-body); padding: 12px 40px; text-decoration: none; display: inline-block; width: auto;">Get Started</a>
        </section>

        <div class="posts-list">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
                
                <div class="post-card">
                    <div class="post-media-placeholder" style="font-family: var(--font-display);">Share Finds</div>
                    <h3 class="post-author" style="font-family: var(--font-display);">Share Your Finds</h3>
                    <p class="post-content" style="font-family: var(--font-body);">Upload photos and videos of your amazing thrift store discoveries</p>
                </div>

                <div class="post-card">
                    <div class="post-media-placeholder" style="font-family: var(--font-display);">Discover Stores</div>
                    <h3 class="post-author" style="font-family: var(--font-display);">Find Local Stores</h3>
                    <p class="post-content" style="font-family: var(--font-body);">Explore thrift stores near you with reviews and details</p>
                </div>

                <div class="post-card">
                    <div class="post-media-placeholder" style="font-family: var(--font-display);">Join Events</div>
                    <h3 class="post-author" style="font-family: var(--font-display);">Attend Events</h3>
                    <p class="post-content" style="font-family: var(--font-body);">Discover and RSVP to local thrifting events and meetups</p>
                </div>

            </div>
        </div>
    </main>

    <%- include('components/footer') %>

</body>
</html>