<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpThrift – Post Details</title>
  <link rel="stylesheet" href="/css/mainlogin.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
</head>
<body>

  <%- include('components/topbar') %>

  <div class="navigation">
    <%- include('components/sidebar', { activePage }) %>
    
    <main class="main-content main-content--events">

      <span class="breadcrumb-tag" style="display:inline-block;margin-bottom:14px;">EVENTS</span>
      <h1 class="page-title">Upcoming Events</h1>

      <div class="events-list-hint">EVENTS LIST</div>

      <div class="events-list">
        <% events.forEach(event => { %>
        <div class="event-card">
            <div class="event-card-img">
              <% if (event.image) { %>
                <img src="<%= event.image %>" alt="<%= event.title %>" class="event-thumb-img">
              <% } else { %>
                <span class="event-thumb-icon">📅</span>
              <% } %>
            </div>
          <div class="event-card-body">
            <h2 class="event-title"><%= event.title %></h2>
            <ul class="event-meta-list">
              <li class="event-meta-item">
                <img src="/images/Calendar.png" alt="Date" style="height: 16px;">
                <%= event.date %>
              </li>
              <li class="event-meta-item">
                <img src="/images/Clock2.png" alt="Time" style="height: 16px;">
                <%= event.time %>
              </li>
              <li class="event-meta-item">
                <img src="/images/MapPin2.png" alt="Location" style="height: 16px;">
                <%= event.location %>
              </li>
              <li class="event-meta-item">
                <img src="/images/Users.png" alt="Attendees" style="height: 16px;">
                <%= event.attendees %> people attending
              </li>
            </ul>
          </div>
          <div class="event-card-actions">
            <a href="/events/<%= event.slug %>" class="btn-view-details">View Details</a>
            <form action="/events/<%= event.slug %>/rsvp" method="POST">
              <button type="submit" class="btn-rsvp">RSVP</button>
            </form>
          </div>
        </div>
        <% }) %>
      </div>

    </main>
  </div>
  <%- include('components/footerlogin') %>
</body>
</html>

