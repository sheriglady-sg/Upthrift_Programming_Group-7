<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup | UpThrift</title>
    <link rel="stylesheet" href="/css/mainlogin.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <style>
        .signup-body {
            background-color: #f2f2ee;
            font-family: var(--font-body);
        }
        .form-content {
            padding: 40px 12%;
        }
        .signup-badge {
            background: #e9e9e9;
            padding: 6px 14px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1px;
            color: var(--color-text-secondary);
            border-radius: 4px;
            font-family: var(--font-body);
        }
        .page-title {
            font-family: var(--font-display);
            font-size: 36px;
            margin-top: 20px;
            color: var(--color-text-primary);
        }
        .login-link-text {
            margin-top: 20px;
            font-size: 14px;
            color: var(--color-text-secondary);
            font-family: var(--font-body);
        }
        .login-link-text a {
            color: #4a6fa5;
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>
<body class="signup-body">

    <%- include('components/topbar-guest') %>

    <main class="split-container" style="min-height: 85vh;">
        <section class="form-side">
            <div class="form-content">
                <span class="signup-badge">SIGNUP</span>
                
                <h1 class="page-title">Create Account</h1>
                <p class="post-content" style="margin-bottom: 25px; font-family: var(--font-body);">Join the UPTHRIFT community</p>

                <% if (message) { %>
                    <div class="form-message success-message"><%= message %></div>
                <% } %>

                <% if (error) { %>
                    <div class="form-message error-message"><%= error %></div>
                <% } %>

                <form action="/auth/signup" method="POST" class="styled-form" style="max-width: 420px;">
                    <div class="form-group">
                        <label class="form-label" style="font-family: var(--font-body); font-weight: 500;">Username</label>
                        <input type="text" name="username" class="comment-input" placeholder="JaneDoe" required>
                    </div>

                    <div class="form-group" style="margin-top: 15px;">
                        <label class="form-label" style="font-family: var(--font-body); font-weight: 500;">Email</label>
                        <input type="email" name="email" class="comment-input" placeholder="your@email.com" required>
                    </div>

                    <div class="form-group" style="margin-top: 15px;">
                        <label class="form-label" style="font-family: var(--font-body); font-weight: 500;">Password</label>
                        <input type="password" name="password" class="comment-input" placeholder="........" required>
                    </div>

                    <div class="form-group" style="margin-top: 15px;">
                        <label class="form-label" style="font-family: var(--font-body); font-weight: 500;">Confirm Password</label>
                        <input type="password" name="confirmPassword" class="comment-input" placeholder="........" required>
                    </div>

                    <button type="submit" class="btn-post" style="width: 100%; margin-top: 25px; padding: 14px; border: none; cursor: pointer;">
                        Create Account
                    </button>

                    <p class="login-link-text">
                        Already have an account? <a href="/login">Sign in</a>
                    </p>
                </form>
            </div>
        </section>

        <section class="image-side">
            <img src="/images/Signup.png" alt="Thrift Store Rack" style="width: 100%; height: 100%; object-fit: cover;">
        </section>
    </main>

    <%- include('components/footer') %>

</body>
</html>
