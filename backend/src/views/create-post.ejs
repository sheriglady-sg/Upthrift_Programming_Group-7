<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpThrift – Share Your Find</title>
  <link rel="stylesheet" href="/css/mainlogin.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
</head>
<body>
<!-- topbar -->
  <%- include('components/topbar') %>
<!-- sidebar -->
  <div class="navigation">
    <%- include('components/sidebar', { activePage }) %>

    <main class="main-content main-content--create">
      <div class="page-header-row page-header-row--details">
        <!-- back button -->
        <a href="/feed" class="back-link">

          <span class="back-arrow">←</span> Back to Feed
        </a>
        <span class="breadcrumb-tag">CREATE POST – UPLOAD PHOTO/VIDEO</span>
      </div>

      <h1 class="page-title">Share Your Find</h1>
<!-- notification succes/error -->
      <% if (message) { %>
        <div class="form-message success-message"><%= message %></div>
      <% } %>

      <% if (error) { %>
        <div class="form-message error-message"><%= error %></div>
      <% } %>

      <div class="create-post-form-wrapper">
        <form action="/posts" method="POST" enctype="multipart/form-data" class="create-post-form">
<!-- poster username -->
          <div class="form-group">
            <label class="form-label">Username</label>
            <input
              class="form-input"
              type="text"
              value="<%= username || '' %>"
              placeholder="Login first to load username"
              readonly
            />
            <input type="hidden" name="user_id" value="<%= userId %>">
          </div>
<!-- post category -->
          <div class="form-group">
            <label class="form-label">Category</label>
            <select class="form-input" name="category" required>
              <option value="">Select a category</option>
              <option value="Thrift Find">Thrift Find</option>
              <option value="Upcycling">Upcycling</option>
              <option value="Clothing">Clothing</option>
              <option value="Home Decor">Home Decor</option>
            </select>
          </div>
<!-- post description -->
          <div class="form-group">
            <label class="form-label">Description</label>
            <textarea
              class="form-textarea"
              name="caption"
              placeholder="Tell us about your thrift find or upcycling project..."
              rows="3"
            ></textarea>
          </div>
<!-- post location -->
          <div class="form-group">
            <label class="form-label">Location</label>
            <input
              class="form-input"
              type="text"
              name="location_tag"
              placeholder="Optional location"
            />
          </div>
<!-- Upload Media -->
          <div class="form-group">
            <label class="form-label">Upload Media</label>
            <div class="upload-drop-zone" id="dropZone">
              <div class="upload-icon-placeholder">↑</div>
              <p class="upload-label">Drag and drop your photos or videos here</p>
              <p class="upload-note">You can upload one photo or one video for this post.</p>
              <p class="upload-or">or</p>
              <button type="button" class="btn-browse" onclick="document.getElementById('fileInput').click()">Browse Files</button>
              <input type="file" id="fileInput" name="media" accept="image/*,video/*" style="display:none" onchange="handleFiles(this.files)" />
            </div>
<!-- upload media -->
            <div class="upload-type-btns">
              <button type="button" class="btn-upload-type" onclick="document.getElementById('fileInput').click()">
                <img src="/images/Image_01.svg" alt="Add Photo" style="height: 20px;">Add Photo  
              </button>
              <button type="button" class="btn-upload-type" onclick="document.getElementById('fileInput').click()">
                <img src="/images/Video.svg" alt="Add Video" style="height: 20px;">Add Video
              </button>
            </div>
<!-- post preview -->
            <div class="media-preview-area" id="previewArea">
              <span class="preview-placeholder-text">Preview area for uploaded media</span>
            </div>
          </div>
<!-- post/cancel buttons -->
          <div class="form-actions">
            <a href="/feed" class="btn-cancel">Cancel</a>
            <button type="submit" class="btn-post">Post</button>
          </div>

        </form>
      </div>
    </main>
  </div>
<!-- footer -->
  <%- include('components/footerlogin') %>

  <script src="/js/create-post.js"></script>
</body>
</html>
