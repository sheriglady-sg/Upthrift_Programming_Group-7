<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | UpThrift</title>
    <link rel="stylesheet" href="/css/mainlogin.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <style>
        
        .comment-input:focus {
            outline: none;
            border-color: var(--color-accent) !important;
            box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
        }

        .success-message {
            background-color: #f6ffed;
            border: 1px solid #b7eb8f;
            color: #52c41a;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
            text-align: center;
        }

        
        .split-container {
            display: flex;
            flex-wrap: wrap;
            align-items: stretch;
        }
        .form-side, .image-side {
            flex: 1;
            min-width: 300px;
        }
    </style>
</head>
<body class="contact-page-v2" style="font-family: var(--font-body);">

    <%- include('components/topbar-guest') %>

    <main class="split-container">
        <section class="form-side">
            <div class="form-content" style="padding: 40px 10%;">

                <h1 class="page-title" style="font-family: var(--font-display); font-size: 36px; margin-top: 15px;">Get in Touch</h1>

                <p class="post-content" style="font-family: var(--font-body); margin-bottom: 30px; color: var(--color-text-secondary);">
                    Have questions or feedback? We'd love to hear from you.
                </p>

                <% if (typeof message !== 'undefined' && message) { %>
                    <div class="success-message">✨ <%= message %></div>
                <% } %>

                <form action="/send-message" method="POST" class="styled-form">
                    <div class="form-group">
                        <label class="form-label" style="font-family: var(--font-body); font-weight: 500;">Name</label>
                        <input type="text" name="name" class="comment-input" style="font-family: var(--font-body);" placeholder="Your name" required>
                    </div>

                    <div class="form-group" style="margin-top: 15px;">
                        <label class="form-label" style="font-family: var(--font-body); font-weight: 500;">Email</label>
                        <input type="email" name="email" class="comment-input" style="font-family: var(--font-body);" placeholder="your@email.com" required>
                    </div>

                    <div class="form-group" style="margin-top: 15px;">
                        <label class="form-label" style="font-family: var(--font-body); font-weight: 500;">Message</label>
                        <textarea name="message" class="comment-input" style="font-family: var(--font-body); height: 120px; border-radius: 12px; padding-top: 12px;" placeholder="Your message..." required></textarea>
                    </div>

                    <button type="submit" class="btn-post" style="font-family: var(--font-body); width: 100%; margin-top: 20px; border: none; cursor: pointer; font-weight: 600; padding: 12px;">
                        Send Message
                    </button>
                </form>
            </div>
        </section>

        <section class="image-side">
            <img src="/images/contact.jpg" alt="Thrift Store Interior" style="width: 100%; height: 100%; min-height: 400px; object-fit: cover; display: block;">
        </section>
    </main>

    <%- include('components/footer') %>

</body>
</html>