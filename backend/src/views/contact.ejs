<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | UpThrift</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="contact-page">

     <%- include('partials/topbar') %>

    <main class="split-container">
        <section class="form-side">
            <div class="form-content">
                <span class="badge">CONTACT</span>
                <h1>Get in Touch</h1>
                <p class="subtitle">Have questions or feedback? We'd love to hear from you.</p>

                <form action="/send-message" method="POST" class="styled-form">
                    <div class="input-field">
                        <label>Name</label>
                        <input type="text" name="name" placeholder="Your name">
                    </div>
                    <div class="input-field">
                        <label>Email</label>
                        <input type="email" name="email" placeholder="your@email.com">
                    </div>
                    <div class="input-field">
                        <label>Message</label>
                        <textarea name="message" rows="4" placeholder="Your message..."></textarea>
                    </div>
                    <button type="submit" class="send-btn">Send Message</button>
                </form>
            </div>
        </section>

        <section class="image-side">
            <img src="/images/contact.png" alt="Thrift Store Interior">
        </section>
    </main>

    <%- include('partials/footer') %>

</body>
</html>
