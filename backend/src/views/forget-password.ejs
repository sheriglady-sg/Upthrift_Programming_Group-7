<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password | UpThrift</title>
    <link rel="stylesheet" href="/css/mainlogin.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <style>
        .reset-body {
            background-color: #f2f2ee;
            font-family: var(--font-body);
        }
        .form-content {
            padding: 80px 12%;
        }
        .reset-badge {
            background: #e9e9e9;
            padding: 6px 14px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1px;
            color: var(--color-text-secondary);
            border-radius: 4px;
            text-transform: uppercase;
        }
        .page-title {
            font-family: var(--font-display);
            font-size: 36px;
            margin-top: 20px;
            color: var(--color-text-primary);
        }
        .back-to-login {
            margin-top: 25px;
            font-size: 14px;
            color: var(--color-text-secondary);
        }
        .back-to-login a {
            color: #4a6fa5;
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>
<body class="reset-body">

    <%- include('components/topbar-guest') %>

    <main class="split-container" style="min-height: 85vh;">
        <section class="form-side">
            <div class="form-content">
                
                <h1 class="page-title">Reset Password</h1>
                <p class="post-content" style="margin-bottom: 30px; line-height: 1.5;">
                    Enter your email and we'll send you <br>
                    a link to reset your password.
                </p>

                <% if (message) { %>
                    <div class="form-message success-message"><%= message %></div>
                <% } %>

                <% if (error) { %>
                    <div class="form-message error-message"><%= error %></div>
                <% } %>

                <form action="/auth/forgot-password" method="POST" class="styled-form" style="max-width: 400px;">
                    <div class="form-group">
                        <label class="form-label" style="font-weight: 500;">Email</label>
                        <input type="email" name="email" class="comment-input" placeholder="your@email.com" required>
                    </div>

                    <button type="submit" class="btn-post" style="width: 100%; margin-top: 30px; padding: 14px; border: none; cursor: pointer;">
                        Send Reset Link
                    </button>

                    <p class="back-to-login">
                        Remember your password? <a href="/login">Sign in</a>
                    </p>
                </form>
            </div>
        </section>

        <section class="image-side">
            <img src="/images/forget.jpg" alt="Thrift Store Interior" style="width: 100%; height: 100%; object-fit: cover;">
        </section>
    </main>

    <%- include('components/footer') %>

</body>
</html>
